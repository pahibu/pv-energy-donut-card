{
  "name": "pv-energy-donut-card",
  "version": "0.1.0",
  "description": "A Home Assistant custom card for photovoltaic production and consumption donut charts.",
  "type": "module",
  "main": "dist/pv-energy-donut-card.js",
  "module": "dist/pv-energy-donut-card.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "hacs.json"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "dev:preview": "node scripts/dev-preview.mjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "preview": "npm run build && python3 -m http.server 4173 --bind 127.0.0.1"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "photovoltaic",
    "solar",
    "chart"
  ],
  "homepage": "https://github.com/pahibu/pv-energy-donut-card",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pahibu/pv-energy-donut-card.git"
  },
  "bugs": {
    "url": "https://github.com/pahibu/pv-energy-donut-card/issues"
  },
  "author": "pahibu",
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.5.0",
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "rollup": "^4.40.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
